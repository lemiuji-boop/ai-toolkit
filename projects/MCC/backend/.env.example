# Ключ шифрования API-ключей провайдеров (Fernet, SEC-003). ОБЯЗАТЕЛЕН.
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32

# Публичный URL сервиса (TZ-FINAL §4)
PUBLIC_BASE_URL=https://matnorm.lan

# БД: PostgreSQL (решение 2026-06-10; контейнер postgres из docker-compose).
# Хост-режим: docker compose up -d postgres, затем localhost:5432.
# Для тестов/разработки без Docker остаётся sqlite-фолбэк (значение по умолчанию в config.py).
DATABASE_URL=postgresql+asyncpg://matnorm:<POSTGRES_PASSWORD>@localhost:5432/matnorm

# SEC-001: внешние провайдеры ИИ (Claude/OpenAI/DeepSeek/MiMo/Kimi) участвуют
# в маршрутизации и сетевых пробах только при значении 1. По умолчанию — 0.
# Решение пользователя 2026-06-10: egress разрешён для НЕконфиденциальных задач,
# поэтому на пилоте значение 1. Конфиденциальные (КД) — всегда только kind=local (FR-081).
ALLOW_EXTERNAL_PROVIDERS=1

# Учётка администратора (вход в админ-панель, T-16). Пустой ADMIN_PASSWORD —
# вход отключён (503 AUTH_DISABLED). Сгенерировать: openssl rand -hex 12
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
# Срок действия JWT, минут
JWT_TTL_MINUTES=720

# Локальный Ollama (единственный внешний для бэкенда вызов по SEC-001)
INFERENCE_URL=http://localhost:11434

# Vision-Language Model для распознавания чертежей (POST /api/jobs → vision.extract)
# Проверенные варианты на RTX 3060 6 ГБ (аудит 2026-06-09):
#   qwen3-vl:8b-instruct  — рекомендуется: llm, ~40 с/страница, confidence ~0.91
#   qwen3-vl:8b           — медленно; при INFERENCE_TIMEOUT=120 уходит в stub
#   qwen2.5vl:3b          — лёгкая; должна быть установлена: ollama pull qwen2.5vl:3b
# Список моделей: curl http://127.0.0.1:11434/api/tags
VLM_MODEL=qwen3-vl:8b-instruct

# Таймаут ответа VLM, сек (для 8B на 6 ГБ VRAM — не менее 180)
INFERENCE_TIMEOUT=180

# OCR и порог уверенности (FR-002/003)
IMAGE_DPI=200
OCR_ENABLED=true
CONF_THRESHOLD=0.7

# Входимость: кратность на самолёто-комплект
SETS_PER_AIRCRAFT=1

# CORS: надстройка Excel (LAN HTTPS), локальная админка; tunnel — опционально
# Подставьте фактический LAN IP после ./scripts/start-matnorm-stack.sh
# CORS_ORIGINS=["https://192.168.x.x:8123","http://127.0.0.1:3010","http://localhost:3010"]
CORS_ORIGIN_REGEX=^https://192\.168\.[0-9]+\.[0-9]+(:[0-9]+)?$|^https://[a-z0-9-]+\.trycloudflare\.com$

# URL локальных сервисов (пробы админ-панели, только localhost)
BACKEND_URL=http://127.0.0.1:8123
RAG_URL=http://127.0.0.1:8020
ADDIN_URL=http://127.0.0.1:3000
