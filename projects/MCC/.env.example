# Переменные docker-compose (скопируйте в .env и задайте секреты).
# .env не коммитится (.gitignore).

# PostgreSQL (сервис postgres в docker-compose.yml)
POSTGRES_USER=matnorm
POSTGRES_DB=matnorm
# Сгенерировать: openssl rand -hex 16
POSTGRES_PASSWORD=change-me

# Порты публикации (по умолчанию)
# BACKEND_PORT=8123
# RAG_PORT=8020
# ADMIN_PORT=3010
# POSTGRES_PORT=5432

# Egress к внешним ИИ-API для НЕконфиденциальных задач (решение 2026-06-10)
ALLOW_EXTERNAL_PROVIDERS=1
