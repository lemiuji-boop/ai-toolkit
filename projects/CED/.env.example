APP_ENV=dev
DEBUG=true

POSTGRES_DB=ced
POSTGRES_USER=ced
POSTGRES_PASSWORD=ced

DATABASE_URL=postgresql+asyncpg://ced:ced@postgres:5432/ced
SYNC_DATABASE_URL=postgresql://ced:ced@postgres:5432/ced
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me-refresh
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

FILE_STORAGE_ROOT=/data/storage
CATALOG_ROOT=/data/catalog
INBOX_SUBDIR=_INBOX
ARCHIVE_SUBDIR=_ARCHIVE
CATALOG_SUBDIR=catalog
STORAGE_PROBE_CACHE_MINUTES=5
INBOX_CONFIDENCE_THRESHOLD=0.7
ENABLE_INBOX_WATCHER=true
MAX_UPLOAD_BYTES=104857600
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

AI_AGENT_BASE_URL=http://ai-agent:8001
AI_AGENT_API_KEY=change-me-ai
BACKEND_INTERNAL_URL=http://backend:8000
AI_FERNET_KEY=change-me-fernet-key-32bytes!!

AI_REDIS_URL=redis://redis:6379/1
AI_API_KEY=change-me-ai
