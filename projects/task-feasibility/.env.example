# MATFES — скопируйте в .env и заполните

# Ollama (локальные L1 задачи)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL_L1=qwen2.5-coder:7b

# Облачный OpenAI-совместимый API (L2–L4)
CLOUD_API_BASE=https://api.openai.com/v1
CLOUD_API_KEY=

DEFAULT_MODEL_L2=gpt-4o-mini
DEFAULT_MODEL_L3=gpt-4o
DEFAULT_MODEL_L4=gpt-4o

MAX_TOKENS_L1=500
MAX_TOKENS_L2=4096
MAX_TOKENS_L3=8192
MAX_TOKENS_L4=16384

FEASIBILITY_THRESHOLD=0.7

# Цены за 1M токенов (USD)
PRICE_INPUT_PER_MILLION=2.5
PRICE_OUTPUT_PER_MILLION=10.0
PRICE_CACHED_INPUT_PER_MILLION=1.25

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=false
